{
  "name": "daemon",
  "version": "1.0.0",
  "description": "Background service daemon for Dev Dropbox",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && esbuild src/index.ts --bundle --platform=node --target=node18 --external:fsevents --outfile=dist/index.js",
    "dev": "tsc -w",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "core": "*",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.9",
    "@types/ws": "^8.5.10",
    "typescript": "^5.4.5"
  }
}
